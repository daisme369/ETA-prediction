{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/eta/:path*",
      "destination": "https://eta-fastapi-backend.onrender.com/api/eta/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://eta-node-backend.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
